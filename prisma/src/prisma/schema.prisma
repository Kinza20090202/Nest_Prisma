generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  PETUGAS
  STUDENTS
}

// Gunakan model ini saja untuk mewakili Siswa
model Students {
  id        Int      @id @default(autoincrement())
  nis       String   @unique
  name      String
  email     String   @unique // Tambahkan ini
  kelas     String           // Tambahkan ini
  jurusan   String           // Tambahkan ini
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relasi ke Peminjaman
  borrowings Borrowing[]

  // Relasi ke User
  user       user?       

  @@map("students") // Memaksa nama tabel di MySQL jadi "students"
}

model user {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      UserRole
  
  studentId Int?     @unique
  student   Students? @relation(fields: [studentId], references: [id])
  
  createdAt DateTime @default(now())
}

model Book {
  id        Int      @id @default(autoincrement())
  title     String
  author    String
  year      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  borrowings Borrowing[]
}

model Borrowing {
  id         Int       @id @default(autoincrement())
  borrowDate DateTime  @default(now())
  returnDate DateTime? 
  status     String    @default("BORROWED")

  student    Students  @relation(fields: [studentId], references: [id])
  studentId  Int

  book       Book      @relation(fields: [bookId], references: [id])
  bookId     Int

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}